table { border-collapse: collapse; width: 100%; margin: 8pt 0; }
th { background: #e3ede7; border: 1pt solid #9bb3a5; padding: 5pt 7pt; text-align: left; font-size: 10pt; }
td { border: 1pt solid #b9c9bf; padding: 5pt 7pt; font-size: 10pt; vertical-align: top; }
pre { background: #f4f4f4; border: 1pt solid #d8d8d8; padding: 7pt; font-family: Consolas, monospace; font-size: 9pt; }
